# Nansen API keys (get from https://app.nansen.ai)
NANSEN_API_KEY=your_nansen_rest_api_key_here
NANSEN_MCP_KEY=your_nansen_mcp_key_here

# Scanner settings
SCAN_INTERVAL_MINUTES=30
SCAN_CHAINS=ethereum,bnb,solana,base,arbitrum,polygon,optimism,avalanche
SCAN_LIMIT=20

# CLI enrichment (real SM data for these chains, ~12 credits/cycle)
CLI_ENRICH_CHAINS=ethereum,bnb
CLI_ENRICH_MINUTES=30

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
